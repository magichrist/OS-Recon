# ──────────────────────────────────────────────────────────
# OS-RECON — Environment Configuration
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# All variables are optional — features without keys are
# skipped gracefully at runtime.
# ──────────────────────────────────────────────────────────

# ─── AI Analysis Engine (Groq) ───────────────────────────
# Required for the "Cognitive Analysis" tab in the UI.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# ─── External Enrichment Providers ───────────────────────
# Each provider is activated by setting its API key.
# Without keys, enrichment is skipped with no errors.

# Have I Been Pwned — check emails against known breaches
# https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# Dehashed — search leaked credentials (email, username, domain, ip)
# https://dehashed.com — use your login email + API key
DEHASHED_EMAIL=
DEHASHED_KEY=

# Hunter.io — verify email deliverability and find contacts
# https://hunter.io/api-keys
HUNTER_API_KEY=

# Shodan — discover open ports, vulnerabilities, and infrastructure
# https://account.shodan.io/
SHODAN_API_KEY=

# VirusTotal — check domains and IPs against malware detections
# https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=
